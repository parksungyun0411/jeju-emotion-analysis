# ─────────────────────────────────────────────────────────────
# 제주 올인원 앱 — 환경변수 예시 (.env.example)
# 실제 키는 .env.local 에 채워 넣으세요. (.env / .env*.local 은 git 무시)
# 키가 없어도 앱은 기동되며, 해당 기능은 mock/seed/안내로 graceful degradation 됩니다.
# ─────────────────────────────────────────────────────────────

# ── ML 서비스 (탭1: 제주어 번역/감정) ──────────────────────────
# 별도 기동되는 FastAPI(KoBART + 감정 앙상블) 의 베이스 URL.
ML_SERVICE_URL=http://127.0.0.1:8000

# ── Kakao 지도 (탭2 맛집 / 탭3 명소) ───────────────────────────
# 브라우저용 JavaScript 키 (지도 SDK 로드). 없으면 지도 placeholder.
NEXT_PUBLIC_KAKAO_MAP_JS_KEY=
# 서버용 REST API 키 (Kakao Local 장소 검색). 없으면 seed JSON 폴백.
KAKAO_REST_API_KEY=

# ── 인증 (NextAuth: Google + Kakao) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# 세션 암호화 시크릿 (openssl rand -base64 32 로 생성)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── AI 여행경로 (탭3: Claude API) ──────────────────────────────
# 없으면 mock 일정 반환.
ANTHROPIC_API_KEY=

# ── 데이터베이스 (커뮤니티/유저 — Prisma) ──────────────────────
# dev: SQLite 파일. prod: PostgreSQL 등으로 교체.
DATABASE_URL="file:./dev.db"
